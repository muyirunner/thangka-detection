.dmypy.json
dmypy.json
.pyre/
.DS_Store

# ---------- 文档构建 ----------
/site
docs/_build/

# ---------- W&B / MLflow ----------
wandb/

# ---------- 大型数据集 (不上传 GitHub) ----------
/datasets
dataset/train/
dataset/val/

# ---------- 模型权重 (大文件, 不上传 GitHub) ----------
# 注: best.pt / last.pt 太大, 建议通过 Release 或网盘分享
*.pt
*.ts
*.pb
*.onnx
*.engine
*.mlmodel
*.mlpackage
*.torchscript
*.tflite
*.h5
*.mnn
*_saved_model/
*_web_model/
*_openvino_model/
*_paddle_model/
*_ncnn_model/
*_imx_model/
pnnx*
*.rknn
weights/

# ---------- 训练运行目录 ----------
# 保留训练可视化结果 (曲线图、混淆矩阵)
# 但排除大型中间文件
runs/detect/
runs/train/*/weights/
runs/train/*/train_batch*.jpg
runs/train/*/val_batch*.jpg

# ---------- Ultralytics 自动下载资源 ----------
/ultralytics/assets/
calibration_*.npy

# ---------- 视频文件 ----------
*.mp4
*.avi
*.mov
*.mkv
*.webm

# ---------- 保留的文件 (取消忽略) ----------
# 我们需要保留: requirements.txt, 示例图片, 训练结果图
!requirements.txt
!web/examples/*.jpg
!web/examples/*.png
!runs/train/*/results.csv
!runs/train/*/args.yaml
!runs/train/*/*.png
!runs/train/*/labels.jpg
!runs/train/*/results.png
!dataset/data.yaml
!dataset/classes.txt
